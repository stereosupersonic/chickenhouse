- content_for(:title) { "Kalender" }
- content_for(:description) { "Alle Events und Veranstaltungen des Henaheisl e.V. - FC Bayern Fanclub Wartenberg." }

%nav{"aria-label" => "breadcrumb"}
  %ol.breadcrumb
    %li.breadcrumb-item
      = link_to "Home", root_path
    %li.breadcrumb-item.active{"aria-current" => "page"}
      .text-nowrap.fw-bold= "Events"

%h1
  Kalender
  = link_to calendar_url(protocol: "webcal"), title: "Kalender abonnieren", "aria-label": "Kalender abonnieren" do
    %i.fa.fa-calendar-plus{"aria-hidden" => "true"}

- @events.each do | event |
  = render EventPresenter.new(event)

- if @pagy.pages > 1
  %nav{"aria-label" => "Seitennavigation"}
    .d-flex.justify-content-center.mt-4
      = raw pagy_bootstrap_nav @pagy
