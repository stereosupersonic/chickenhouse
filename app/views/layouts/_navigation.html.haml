%nav.navbar.navbar-expand-lg.navbar-light{"aria-label" => "Hauptnavigation"}
  .container-fluid
    = link_to root_path, class: "navbar-brand", "aria-label": "Startseite" do
      %i.fa.fa-home{"aria-hidden" => "true"}

    %button.navbar-toggler{"aria-controls" => "navbarNav", "aria-expanded" => "false", "aria-label" => "Navigation umschalten", "data-bs-target" => "#navbarNav", "data-bs-toggle" => "collapse", type: "button"}
      %span.navbar-toggler-icon

    #navbarNav.collapse.navbar-collapse
      %ul.navbar-nav.me-auto
        %li.nav-item
          = link_to "Kalender", events_path, class: "nav-link"
        %li.nav-item
          = link_to "Blog", posts_path, class: "nav-link"
        %li.nav-item
          = link_to "Über Uns", about_path, class: "nav-link"
        - if admin?
          %li.nav-item
            = link_to "Admin", admin_root_path, class: "nav-link"
        %li.nav-item.d-flex.align-items-center{ data: { controller: "search-toggle" } }
          = form_tag posts_path, method: :get, class: "d-flex align-items-center d-none", role: "search", data: { search_toggle_target: "form" } do
            = text_field_tag :q, params[:q], class: "form-control form-control-sm me-1", placeholder: "Suche...", "aria-label" => "Suche", data: { search_toggle_target: "input" }
          %button.btn.nav-link{ type: "button", "aria-label" => "Suche öffnen", data: { action: "search-toggle#toggle" } }
            %i.fa-solid.fa-magnifying-glass{"aria-hidden" => "true"}

  = render "layouts/personal_box"
